generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Blog {
  id         String   @id @default(cuid())
  title      String
  content    String
  slug       String   @unique
  authorId   String
  authorName String
  createdAt  DateTime @default(now())
  comments   Comment[]
}

model Comment {
  id         String   @id @default(cuid())
  text       String
  blogId     String
  authorName String
  createdAt  DateTime @default(now())

  blog Blog @relation(fields: [blogId], references: [id], onDelete: Cascade)
}

model Booking {
  id                 String   @id @default(cuid())
  name               String
  email              String
  dateTime           DateTime
  serviceType        String
  userId             String
  astrologerId       String?
  amount             Int?
  paymentStatus      String   @default("pending")
  razorpayOrderId    String?
  razorpayPaymentId  String?
  createdAt          DateTime @default(now())
}

model UserProfile {
  id               String    @id @default(cuid())
  clerkUserId      String    @unique
  photoUrl         String?
  gender           String?
  dateOfBirth      DateTime?
  timeOfBirth      String?
  birthTimeUnknown Boolean   @default(false)
  birthCity        String?
  birthState       String?
  birthCountry     String?
  birthLat         Float?
  birthLng         Float?
  birthTimezone    String?
  currentCity      String?
  currentLat       Float?
  currentLng       Float?
  language         String?   @default("English")
  maritalStatus    String?
  caste            String?
  profileComplete  Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}
