generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ASTROLOGER
  ADMIN
}

enum AstrologerStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum ExpertiseEnum {
  ASTROLOGERS        @map("Astrologers")
  TAROT_READERS      @map("Tarot Readers")
  NUMEROLOGISTS      @map("Numerologists")
  VASTU_CONSULTANTS  @map("Vastu Consultants")
  REIKI_HEALERS      @map("Reiki Healers")
  PALMISTS           @map("Palmists")
  PSYCHIC_READERS    @map("Psychic Readers")
  SPIRITUAL_HEALERS  @map("Spiritual Healers")
  GEMSTONE_EXPERTS   @map("Gemstone Experts")
  LAL_KITAB_EXPERTS  @map("Lal Kitab Experts")
  FACE_READERS       @map("Face Readers")
  AURA_READERS       @map("Aura Readers")
  PRANIC_HEALERS     @map("Pranic Healers")
  NADI_ASTROLOGERS   @map("Nadi Astrologers")
  CRYSTAL_HEALERS    @map("Crystal Healers")
  LIFE_COACHES       @map("Life Coaches")
  MEDITATION_COACHES @map("Meditation Coaches")
  PANDITS            @map("Pandits (for Puja Booking)")
  DREAM_ANALYSTS     @map("Dream Analysts")
}

enum LanguageEnum {
  HINDI      @map("Hindi")
  ENGLISH    @map("English")
  TAMIL      @map("Tamil")
  TELUGU     @map("Telugu")
  MARATHI    @map("Marathi")
  BENGALI    @map("Bengali")
  GUJARATI   @map("Gujarati")
  KANNADA    @map("Kannada")
  MALAYALAM  @map("Malayalam")
  PUNJABI    @map("Punjabi")
  ODIA       @map("Odia")
}

enum ConsultMode {
  CHAT
  VOICE
  VIDEO
}

enum ConsultStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
  WAITING
  ONGOING
  COMPLETED
  CANCELLED
  MISSED
  TIMED_OUT
}

enum TransactionType {
  RECHARGE
  CONSULTATION_LOCK
  CONSULTATION_DEBIT
  CONSULTATION_REFUND
  PANDIT_CREDIT
  WITHDRAWAL
  ADMIN_CREDIT
}

// ── Auth ──────────────────────────────────────────
model User {
  id            String      @id @default(cuid())
  name          String
  email         String      @unique
  password      String
  mobile        String?
  role          Role        @default(USER)
  walletBalance Int         @default(0) // stored in paisa (₹1 = 100 paisa)
  createdAt     DateTime    @default(now())

  profile           UserProfile?
  astrologerProfile AstrologerProfile?
  bookings          Booking[]
  blogs             Blog[]
  reviews           Review[]
  consultations     Consultation[]
  walletTransactions WalletTransaction[]
  sentMessages      ConsultMessage[]
  notifications     Notification[]
}

// ── Blog ─────────────────────────────────────────
model Blog {
  id         String    @id @default(cuid())
  title      String
  content    String
  slug       String    @unique
  authorId   String
  authorName String
  createdAt  DateTime  @default(now())
  comments   Comment[]

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model Comment {
  id         String   @id @default(cuid())
  text       String
  blogId     String
  authorName String
  createdAt  DateTime @default(now())

  blog Blog @relation(fields: [blogId], references: [id], onDelete: Cascade)
}

// ── Booking (legacy — kept for existing bookings) ─
model Booking {
  id                String   @id @default(cuid())
  name              String
  email             String
  dateTime          DateTime
  serviceType       String
  userId            String
  astrologerId      String?
  amount            Int?
  paymentStatus     String   @default("pending")
  razorpayOrderId   String?
  razorpayPaymentId String?
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── User Profile (astrological details) ──────────
model UserProfile {
  id               String    @id @default(cuid())
  userId           String    @unique
  photoUrl         String?
  gender           String?
  dateOfBirth      DateTime?
  timeOfBirth      String?
  birthTimeUnknown Boolean   @default(false)
  birthCity        String?
  birthState       String?
  birthCountry     String?
  birthLat         Float?
  birthLng         Float?
  birthTimezone    String?
  currentCity      String?
  currentLat       Float?
  currentLng       Float?
  language         String?   @default("English")
  maritalStatus    String?
  caste            String?
  profileComplete  Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Astrologer Profile ───────────────────────────
model AstrologerProfile {
  id                 String           @id @default(cuid())
  userId             String           @unique
  profileImage       String?
  displayName        String?
  experience         Int?
  bio                String?
  expertise          ExpertiseEnum[]
  languages          LanguageEnum[]
  aadhaarNumber      String?
  panNumber          String?
  chatPrice          Int?
  callPrice          Int?
  videoCallPrice     Int?
  workingDays        String[]
  timeSlots          String[]
  availability       Json?
  pricingPackages    Json?
  website            String?
  instagram          String?
  facebook           String?
  youtube            String?
  verificationStatus AstrologerStatus @default(PENDING)
  profileCompletion  Int              @default(0)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  ratingAverage      Float            @default(1)
  totalReviews       Int              @default(0)
  isOnline           Boolean          @default(false)
  supportsChat       Boolean          @default(true)
  supportsVoice      Boolean          @default(true)
  supportsVideo      Boolean          @default(true)
  status             String           @default("active")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews            Review[]
  consultations      Consultation[]
}

// ── Reviews ───────────────────────────────────────
model Review {
  id               String   @id @default(cuid())
  panditId         String
  userId           String
  consultationId   String?  @unique
  rating           Int      // 1-10 scale
  comment          String?
  createdAt        DateTime @default(now())

  pandit           AstrologerProfile @relation(fields: [panditId], references: [id], onDelete: Cascade)
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  consultation     Consultation?     @relation(fields: [consultationId], references: [id])
}

// ── Consultation ──────────────────────────────────
model Consultation {
  id               String        @id @default(cuid())
  userId           String
  panditId         String
  mode             ConsultMode
  status           ConsultStatus @default(PENDING)
  isInstant        Boolean       @default(true) // true = Chat Now, false = Scheduled
  scheduledTime    DateTime?
  startedAt        DateTime?
  endedAt          DateTime?
  totalMinutes     Int           @default(0)
  totalCost        Int           @default(0)    // paisa
  pricePerMinute   Int           @default(0)    // paisa — locked at creation
  lockedAmount     Int           @default(0)    // paisa — wallet amount locked
  description      String?
  streamChannelId  String?       // GetStream channel ID
  streamCallId     String?       // GetStream call ID
  expiresAt        DateTime?     // auto-expire for pending requests
  joinExpiresAt    DateTime?     // user/pandit must join within 3 min of accept
  billingStartedAt DateTime?
  createdAt        DateTime      @default(now())

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  pandit           AstrologerProfile @relation(fields: [panditId], references: [id], onDelete: Cascade)
  messages         ConsultMessage[]
  transactions     WalletTransaction[]
  events           ConsultEvent[]
  review           Review?
}

// ── Consultation Messages ─────────────────────────
model ConsultMessage {
  id              String    @id @default(cuid())
  consultationId  String
  senderId        String
  messageText     String
  messageType     String    @default("text") // text, image, audio, document
  streamMessageId String?   // GetStream message ID for sync
  createdAt       DateTime  @default(now())
  readAt          DateTime?

  consultation    Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  sender          User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

// ── Consultation Events (audit log) ──────────────
model ConsultEvent {
  id              String    @id @default(cuid())
  consultationId  String
  eventType       String    // REQUEST_CREATED, ACCEPTED, REJECTED, TIMER_STARTED, MINUTE_BILLED, SESSION_ENDED, etc.
  metadata        Json?
  createdAt       DateTime  @default(now())

  consultation    Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
}

// ── Wallet Transactions ──────────────────────────
model WalletTransaction {
  id                String          @id @default(cuid())
  userId            String
  consultationId    String?
  type              TransactionType
  amount            Int             // paisa (positive = credit, negative = debit)
  balanceBefore     Int
  balanceAfter      Int
  description       String
  razorpayOrderId   String?
  razorpayPaymentId String?
  createdAt         DateTime        @default(now())

  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  consultation      Consultation? @relation(fields: [consultationId], references: [id])
}

// ── Notifications ────────────────────────────────
model Notification {
  id          String    @id @default(cuid())
  userId      String
  title       String
  body        String
  type        String    // NEW_REQUEST, ACCEPTED, REJECTED, LOW_BALANCE, SESSION_STARTED, SESSION_ENDED, REVIEW_REMINDER
  metadata    Json?
  read        Boolean   @default(false)
  createdAt   DateTime  @default(now())

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
